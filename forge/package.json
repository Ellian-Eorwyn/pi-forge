{
	"name": "@ellian-eorwyn/pi-forge",
	"version": "0.79.8",
	"description": "pi-forge package with managed skills, MCP bridge, and launchers for Pi.",
	"type": "module",
	"private": false,
	"keywords": [
		"pi-package",
		"agent-skills"
	],
	"bin": {
		"pi-forge": "bin/pi-forge.mjs",
		"pi-forge-mcp": "bin/pi-forge-mcp.mjs",
		"pi-forge-update": "bin/pi-forge-update.mjs"
	},
	"files": [
		"AGENTS.md",
		"README.md",
		"CHANGELOG.md",
		"bin/",
		"scripts/",
		"extensions/",
		"skills/",
		"prompts/",
		"themes/",
		"lib/",
		"!node_modules/",
		"!**/.DS_Store",
		"!**/__pycache__/",
		"!**/*.pyc"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.79.8",
		"@modelcontextprotocol/sdk": "1.29.0",
		"playwright": "1.61.0",
		"typebox": "1.1.38",
		"zod": "4.4.3"
	},
	"pi": {
		"extensions": [
			"extensions"
		],
		"skills": [
			"skills"
		],
		"prompts": [
			"prompts"
		],
		"themes": [
			"themes"
		]
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
